{
  "buildCommand": "vite build && npx esbuild api-src/index.ts --bundle --platform=node --format=cjs --outfile=api/index.js --external:mongoose --external:express --external:cors --external:dotenv --external:bcryptjs",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
