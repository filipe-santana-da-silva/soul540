{
  "name": "soul540",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "start": "tsx server/index.ts",
    "dev": "vite",
    "build": "tsc && vite build && npm run build:franchise && npm run build:factory",
    "build:franchise": "cd franchise && npm ci && npm run build",
    "build:factory": "cd factory && npm ci && npm run build",
    "preview": "vite preview",
    "server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "seed": "tsx server/seed.ts",
    "seed:units": "tsx server/seed-units.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "tsx": "^4.15.7",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "html2pdf.js": "^0.14.0",
    "mongoose": "^8.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "recharts": "^2.12.7",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "sass": "^1.77.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.1"
  }
}
